  ],
  "cases": [
    {
      "name": "arith-let-star",
      "expr": "(let* ((x 1) (y (1+ x))) (+ x y))",
      "expect": "3"
    },
    {
      "name": "case-list-hit",
      "expr": "(case 'b ((a c) 1) ((b d) 2) (otherwise 3))",
      "expect": "2"
    },
    {
      "name": "append-and-reverse",
      "expr": "(reverse (append '(1 2) '(3 4)))",
      "expect": "(4 3 2 1)"
    },
    {
      "name": "mapcar-two-lists",
      "expr": "(mapcar (function +) '(1 2) '(10 20))",
      "expect": "(11 22)"
    },
    {
      "name": "reduce-plus",
      "expr": "(reduce (function +) '(1 2 3 4))",
      "expect": "10"
    },
    {
      "name": "dotimes-accumulator-loop",
      "expr": "(let ((acc nil)) (dotimes (i 5 acc) (setq acc (cons i acc))))",
      "expect": "(4 3 2 1 0)"
    },
    {
      "name": "dotimes-result-var-is-count",
      "expr": "(dotimes (i 3 i))",
      "expect": "3"
    },
    {
      "name": "dotimes-negative-count-result",
      "expr": "(dotimes (i -2 i))",
      "expect": "-2"
    },
    {
      "name": "dolist-sum-loop",
      "expr": "(let ((s 0)) (dolist (x '(1 2 3) s) (setq s (+ s x))))",
      "expect": "6"
    },
    {
      "name": "dolist-result-var-is-nil",
      "expr": "(dolist (x '(1 2 3) x))",
      "expect": "nil"
    },
    {
      "name": "nested-dotimes-dolist",
      "expr": "(let ((s 0)) (dotimes (i 3 s) (dolist (x '(10 20) nil) (setq s (+ s (+ i x))))))",
      "expect": "96"
    },
    {
      "name": "every-plusp",
      "expr": "(every (function plusp) '(1 2 3))",
      "expect": "t"
    },
    {
      "name": "some-bare-lambda",
      "expr": "(some (lambda (x) (if (> x 2) x nil)) '(1 2 3))",
      "expect": "3"
    },
    {
      "name": "getf-keyword",
      "expr": "(getf '(:a 1 :b 2) ':b)",
      "expect": "2"
    },
    {
      "name": "string-trim",
      "expr": "(string-trim \" -\" \" --hi- \")",
      "expect": "\"hi\""
    },
    {
      "name": "string-upcase",
      "expr": "(string-upcase \"Az-09\")",
      "expect": "\"AZ-09\""
    },
    {
      "name": "format-decimal",
      "expr": "(format nil \"x=~D\" 42)",
      "expect": "\"x=42\""
    },
    {
      "name": "format-readable-string",
      "expr": "(format nil \"~S\" \"hi\")",
      "expect": "\"\"hi\"\""
    }
  ]
}
