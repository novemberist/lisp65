{
  "format": "lisp65-bytecode-p0-disk-lib-suite-v1",
  "name": "fixed",
  "d81_name": "FIXED",
  "provides": [
    "fx-scale",
    "integer->fx",
    "fx",
    "fx->integer",
    "fx+",
    "fx-",
    "fx*",
    "fx/",
    "fx<"
  ],
  "requires": [
    "core"
  ],
  "description": "Fixed-point pilot bytecode disk library. Q8.7 helpers packaged as an on-demand library against the resident einsuite-core suite.",
  "sources": [
    "lib/stdlib-fixed.lisp"
  ],
  "functions_from_sources": [
    "lib/stdlib-fixed.lisp"
  ],
  "require_all_defuns": true,
  "resident_suite": "../stdlib/p0-stdlib-einsuite-core-subset.json",
  "max_call_args": 12,
  "cases": [
    {
      "name": "fx-scale",
      "expr": "(fx-scale)",
      "expect": "128"
    },
    {
      "name": "integer-to-fx",
      "expr": "(integer->fx 3)",
      "expect": "384"
    },
    {
      "name": "fx-fraction",
      "expr": "(fx 1 64)",
      "expect": "192"
    },
    {
      "name": "fx-to-integer-positive",
      "expr": "(fx->integer (fx 3 100))",
      "expect": "3"
    },
    {
      "name": "fx-to-integer-negative",
      "expr": "(fx->integer (fx -3 -100))",
      "expect": "-3"
    },
    {
      "name": "fx-add",
      "expr": "(fx+ (fx 1 64) (fx 2 32))",
      "expect": "480"
    },
    {
      "name": "fx-subtract",
      "expr": "(fx- (fx 2 0) (fx 0 64))",
      "expect": "192"
    },
    {
      "name": "fx-negate",
      "expr": "(fx- (fx 1 0))",
      "expect": "-128"
    },
    {
      "name": "fx-multiply-positive",
      "expr": "(fx* (fx 1 64) (fx 2 0))",
      "expect": "384"
    },
    {
      "name": "fx-multiply-negative",
      "expr": "(fx* (fx -1 -64) (fx 2 0))",
      "expect": "-384"
    },
    {
      "name": "fx-divide-half",
      "expr": "(fx/ (fx 7 0) (fx 2 0))",
      "expect": "448"
    },
    {
      "name": "fx-divide-quarter",
      "expr": "(fx/ (fx 1 0) (fx 4 0))",
      "expect": "32"
    },
    {
      "name": "fx-less-true",
      "expr": "(fx< (fx 1 0) (fx 1 64))",
      "expect": "t"
    }
  ]
}
