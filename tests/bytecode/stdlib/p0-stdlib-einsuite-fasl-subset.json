   "reason": "provided by the resident Workbench screen runtime"
  }
 ],
 "vm_dir_max": 408,
 "vm_dir_align8_after_boot": true,
 "min_vm_dir_headroom": 8,
 "sources": [
  "lib/stdlib-load.lisp",
  "lib/lcc-fasl.lisp"
 ],
