    },
    {
      "name": "v11-filter-direct",
      "invoke": "direct",
      "expr": "(filter (function numberp) '(a 2 b 3))",
      "expect": "(2 3)"
    },
    {
      "name": "v11-filter-funcall",
      "invoke": "funcall",
      "expr": "(funcall (function filter) (function numberp) '(a 2 b 3))",
      "expect": "(2 3)"
    }
  ]
}
